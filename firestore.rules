rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Customers: own profile only ──
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── System: public read for hero images & sale config; cmsAdmin private ──
    match /system/{doc} {
      allow read: if doc != 'cmsAdmin';
      allow write: if false; // CMS writes via relaxed rules below
    }

    // ── System (broad): allow CMS to write all system docs ──
    match /system/{doc} {
      allow read, write: if true;
    }

    // ── Products: public read, anyone can write (CMS) ──
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ── Orders: anyone can create (guest checkout), public read/update ──
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if true;
    }

    // ── Promo Codes: public read for validation, anyone can write (CMS) ──
    match /promoCodes/{promoId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ── Customers (CMS admin broad access) ──
    match /customers/{userId} {
      allow read: if true;
    }

    // ── Enquiries: users can write, public read for CMS ──
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, delete: if true;
    }

    // ── Default deny ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
